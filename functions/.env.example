# Pakumi Cloud Functions — example environment file
#
# Copy this file to functions/.env and fill in the values for local
# emulator runs. functions/.env is gitignored. Never commit real values.
#
# Configuration is wired through firebase-functions/params (see
# functions/index.js header). The params system reads functions/.env
# automatically in v4.3+, so any variable below is picked up by both the
# emulator and `firebase deploy` parameter resolution.

# ── Non-secret config (defineString) ────────────────────────────────

# Twilio delivery status callback endpoint.
# Available only after the first deploy reveals the function URL:
#   https://us-central1-<PROJECT>.cloudfunctions.net/twilioStatusCallback
# Empty value is valid — it disables Layer A delivery observability.
TWILIO_STATUS_CALLBACK_URL=

# ── Secrets (defineSecret) ──────────────────────────────────────────
# Production: stored in Google Cloud Secret Manager. Set once via:
#   firebase functions:secrets:set GEMINI_API_KEY
# Emulators: the params package falls back to functions/.env, so you can
# put a dev key here for local runs. Do NOT use a production key.

GEMINI_API_KEY=

# Twilio account credentials. Used by messages.create for async
# outbound WhatsApp delivery (see debt 0017). Set once via:
#   firebase functions:secrets:set TWILIO_ACCOUNT_SID
#   firebase functions:secrets:set TWILIO_AUTH_TOKEN
#   firebase functions:secrets:set TWILIO_FROM_NUMBER
# For local emulator runs you can put dev/sandbox values here.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox number INCLUDING the "whatsapp:" prefix, e.g.:
#   whatsapp:+14155238886
TWILIO_FROM_NUMBER=
