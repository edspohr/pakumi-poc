rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pet docs — owner-only read/write.
    match /pets/{petId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                                  && resource.data.userId == request.auth.uid;
    }

    // User profile docs — owner-only.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Public emergency profiles — world-readable, owner-only writes.
    // Only populate this with the safe subset:
    // name, species, age, condition, ownerPhone, ownerName.
    match /emergency_profiles/{petId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
                                    && request.resource.data.userId == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
